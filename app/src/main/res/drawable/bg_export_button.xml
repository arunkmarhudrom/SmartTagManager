<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#33FFFFFF">  <!-- Ripple color -->

    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1.5dp" android:color="@color/white" />
            <solid android:color="#33FFFFFF" />  <!-- 20% white background -->
            <corners android:radius="12dp" />
            <padding android:left="12dp" android:right="16dp" android:top="10dp" android:bottom="10dp" />
        </shape>
    </item>
</ripple>