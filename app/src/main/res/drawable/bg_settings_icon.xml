<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">

    <!-- Background color (transparent) -->
    <solid android:color="@android:color/transparent" />

    <!-- Border line -->
    <stroke
        android:width="1.5dp"
        android:color="@color/red_600" />

    <!-- Extra padding for nicer look -->
    <padding
        android:left="6dp"
        android:right="6dp"
        android:top="6dp"
        android:bottom="6dp" />
</shape>
