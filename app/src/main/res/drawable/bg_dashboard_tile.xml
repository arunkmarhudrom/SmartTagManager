<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- rounded corners -->
    <corners android:radius="18dp"/>

    <!-- darker gradient with soft glow (top brighter → center glow → bottom deep blue) -->
    <gradient
        android:angle="270"
        android:startColor="#3F7CF7"
    android:centerColor="#224FCF"
    android:endColor="#102E88"
    android:type="linear" />

    <!-- subtle outer glow stroke -->
    <stroke
        android:width="1dp"
        android:color="#3362AFFF" />   <!-- faint bluish glow -->

    <!-- small padding to avoid corner artifacts -->
    <padding
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp"/>
</shape>
