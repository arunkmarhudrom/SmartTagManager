<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="130dp"
    android:layout_margin="6dp"


    card:cardBackgroundColor="@android:color/transparent"
    card:cardCornerRadius="12dp"
    card:cardElevation="0dp"


    card:cardUseCompatPadding="false"
    card:cardPreventCornerOverlap="false">

<LinearLayout
android:layout_width="match_parent"
android:layout_height="match_parent"
android:background="@drawable/bg_dashboard_tile"
android:gravity="center"
android:orientation="vertical"
android:padding="12dp">

<View
    android:id="@+id/vDot"
    android:layout_width="28dp"
    android:layout_height="28dp"
    android:layout_marginBottom="8dp"
    android:background="@drawable/dot_gradient_default" />

<TextView
    android:id="@+id/tvTitle"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Zone A"
    android:textColor="@android:color/white"
    android:textSize="15sp"
    android:textStyle="bold" />

<TextView
    android:id="@+id/tvSubtitle"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="4dp"
    android:text="Tap to view tasks"
    android:textColor="@android:color/white"
    android:textSize="10sp" />

</LinearLayout>

    </androidx.cardview.widget.CardView>
