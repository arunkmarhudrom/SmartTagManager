<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dashboard_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:orientation="vertical">

    <!-- Header card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/header_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
       android:layout_marginTop="25dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:cardUseCompatPadding="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ROW 1 : Avatar + login details -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_avatar_circle" />

                <TextView
                    android:id="@+id/tvLoggedIn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="Logged in as\nprasunbasu16@gmail.com"
                    android:textSize="15sp" />
            </LinearLayout>

            <!-- SPACE -->
            <Space
                android:layout_width="match_parent"
                android:layout_height="5dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="0dp">

                <!-- TASK -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnManageTasks"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:text="Task"
                    android:textColor="@android:color/white"
                    android:textSize="10sp"
                    app:backgroundTint="@color/blue_600"
                    app:icon="@drawable/ic_task"
                    app:iconGravity="textStart"
                    app:iconPadding="3dp"
                    app:iconTint="@android:color/white"

                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp"
                    android:minWidth="0dp" />

                <!-- REPORT -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReports"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:text="Report"
                    android:textColor="@color/blue_600"
                    android:textSize="10sp"
                    app:backgroundTint="@android:color/white"
                    app:icon="@drawable/ic_report"
                    app:iconGravity="textStart"
                    app:iconPadding="3dp"
                    app:iconTint="@color/blue_600"
                    app:strokeColor="@color/blue_600"
                    app:strokeWidth="1dp"

                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp"
                    android:minWidth="0dp" />

                <!-- LOGOUT -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogout"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="Logout"
                    android:textColor="@android:color/white"
                    android:textSize="10sp"
                    app:backgroundTint="@color/red_600"
                    app:icon="@drawable/ic_logout"
                    app:iconGravity="textStart"
                    app:iconPadding="3dp"
                    app:iconTint="@android:color/white"

                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp"
                    android:minWidth="0dp" />

            </LinearLayout>


        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Select Zone row (flows under the header card) -->
    <LinearLayout
        android:id="@+id/select_zone_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="16dp"
        android:paddingTop="5dp"
        android:paddingRight="16dp"
        android:paddingBottom="5dp">

        <ImageView
            android:id="@+id/ivLocationIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="location icon"
            android:src="@drawable/ic_location"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/tvSelectZone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Select Zone"
            android:textSize="20sp"
            android:textColor="@color/white"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Separator (optional) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#589EEF" />

    <!-- Modules grid (RecyclerView) fills remaining space -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvModules"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingLeft="12dp"
        android:paddingRight="12dp" />

</LinearLayout>
