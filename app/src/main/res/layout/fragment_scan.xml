<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER WITH BACK BUTTON + TITLE -->
        <!-- HEADER WITH BACK BUTTON + TITLE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingBottom="12dp">

            <ImageView
                android:id="@+id/ivBack"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:contentDescription="Back"
                android:src="@drawable/ic_back_arrow"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/tvModuleTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Module A"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- FIX: THIS SPACER PUSHES SETTINGS ICON TO THE RIGHT -->
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- SETTINGS ICON (RIGHT) -->
            <ImageButton
                android:id="@+id/ivSettings"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/bg_settings_icon"

                android:contentDescription="Settings"
                android:padding="6dp"
                android:src="@drawable/setting"
                android:scaleType="centerInside"
                app:tint="@color/red_600" />


        </LinearLayout>


        <!-- CONTENT AREA -->

        <!-- HEADER CARD (not part of list) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardScanHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@android:color/transparent"
            app:cardCornerRadius="10dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#E8EDF6"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- top row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/ivScanIcon"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_radar"
                        app:tint="@color/blue_700" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvHeaderTaskTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Task_2025-12-03_15:45:58"
                            android:textColor="@color/blue_900"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvHeaderSub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Active in Zone C"
                            android:textColor="#4A4A4A"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvHeaderCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0/3"
                        android:textColor="@color/blue_900"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Start/Stop button -->
                <Button
                    android:id="@+id/btnStartStop"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="14dp"
                    android:backgroundTint="@color/blue_600"
                    android:text=""
                    android:textAllCaps="false"
                    android:textColor="@android:color/white" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/circle_green" />

            <TextView
                android:id="@+id/tvSectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Nearby Signals (0)"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>


        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPendingTags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false" />
        </FrameLayout>


    </LinearLayout>
</FrameLayout>
